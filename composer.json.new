
{
    "name": "laravelgpt/gsmui",
    "description": "GSM-UI: Ultimate Laravel Component Library with 400+ components, 80+ payment gateways, and sound effects",
    "type": "library",
    "keywords": [
        "laravel",
        "component-library",
        "ui-components",
        "blade",
        "livewire",
        "react",
        "vue",
        "starter-kit",
        "admin-panel",
        "payment-gateways"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "GSM-UI Team",
            "email": "team@gsm-ui.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/cashier": "^6.0",
        "livewire/livewire": "^4.0",
        "livewire/volt": "^2.0",
        "spatie/laravel-permission": "^6.0",
        "filament/filament": "^3.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "GSMUI\\": "src/",
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GSMUI\\ServiceProvider",
                "GSMUI\\Console\\ConsoleServiceProvider"
            ]
        }
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
