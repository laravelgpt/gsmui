{
    "name": "gsm-ui/marketplace",
    "type": "project",
    "description": "GSM-UI SaaS Marketplace for Forensic Applications",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/cashier": "^6.0",
        "livewire/livewire": "^4.0",
        "livewire/volt": "^2.0",
        "spatie/laravel-permission": "^6.0",
        "filament/filament": "^3.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "platform": {
            "php": "8.2"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
