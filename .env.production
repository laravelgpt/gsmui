
APP_NAME=GSM-UI
APP_ENV=production
APP_KEY=base64:cGFzc3dvcmQgaGFzaA==
APP_DEBUG=false
APP_URL=https://gsm-ui.example.com

# Security
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gsm_ui
DB_USERNAME=homestead
DB_PASSWORD=secret

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@gsm-ui.com
MAIL_FROM_NAME=GSM-UI

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# File Storage
FILESYSTEM_DISK=local

# Pagination
PAGINATION=20

# Queue
QUEUE_CONNECTION=sync

# Cache
CACHE_DRIVER=file
CACHE_PREFIX=gsm_ui_cache

# Broadcasting
BROADCAST_DRIVER=log

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning
LOG_DAILY=true
LOG_MAX_FILES=14

# Rate Limiting
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_API=30
RATE_LIMIT_AUTH=60

# CORS
CORS_ALLOWED_ORIGINS=https://gsm-ui.example.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_ALLOW_CREDENTIALS=true

# Security Headers
SECURITY_HEADERS=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1; mode=block
STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains

# Stripe
STRIPE_ENABLED=true
STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=USD

# PayPal
PAYPAL_ENABLED=true
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_URL=https://api-m.sandbox.paypal.com

# Razorpay
RAZORPAY_ENABLED=false
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_CURRENCY=INR

# Paystack
PAYSTACK_ENABLED=false
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CURRENCY=NGN

# Payment
PAYMENT_DEFAULT_GATEWAY=stripe
PAYMENT_FALLBACK_GATEWAY=stripe

# Sanctum
SANCTUM_STATEFUL_DOMAINS=gsm-ui.example.com

# Broadcasting
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Mix
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
